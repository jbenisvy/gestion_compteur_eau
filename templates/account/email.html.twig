{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="login-card">
    <h1>Mon adresse email</h1>
    <p>Adresse actuelle: <strong>{{ userEmail }}</strong></p>
    <p>Statut vérification: <strong>{{ isVerified ? 'Vérifiée' : 'Non vérifiée' }}</strong></p>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <form method="post" action="{{ path('app_account_email') }}">
        <div class="form-row">
            <label for="newEmail">Nouvelle adresse email</label>
            <input type="email" id="newEmail" name="email" required autocomplete="email">
        </div>
        <input type="hidden" name="_token" value="{{ csrf_token('account_change_email') }}">
        <button class="btn btn-primary" type="submit">Mettre à jour l'email</button>
    </form>

    {% if canManageTwoFactor %}
        <section class="two-factor-panel">
            <div class="two-factor-header">
                <div>
                    <h2>Double authentification</h2>
                    <p>
                        Après le lien envoyé par email, un code à 6 chiffres sera demandé dans Google Authenticator
                        ou Microsoft Authenticator.
                    </p>
                </div>
                <span class="two-factor-state {{ twoFactorEnabled ? 'is-on' : 'is-off' }}">
                    {{ twoFactorEnabled ? 'Activée' : 'Inactive' }}
                </span>
            </div>

            {% if twoFactorSetupSecret %}
                <div class="two-factor-setup">
                    <div class="two-factor-qr-block">
                        <div class="two-factor-qr">
                            <img
                                src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data={{ twoFactorProvisioningUri|url_encode }}"
                                alt="QR code de configuration de la double authentification"
                                width="220"
                                height="220"
                                loading="lazy"
                            >
                        </div>
                        <p class="two-factor-hint">Scannez ce QR code avec votre application.</p>
                    </div>
                    <div class="two-factor-details">
                        <p><strong>Clé manuelle:</strong></p>
                        <code class="two-factor-secret">{{ twoFactorSetupSecret }}</code>
                        <p class="two-factor-hint">Utile si le scan QR n’est pas disponible.</p>
                    </div>
                </div>

                <form method="post" action="{{ path('app_account_two_factor_enable') }}">
                    <div class="form-row">
                        <label for="twoFactorCode">Code de validation</label>
                        <input
                            type="text"
                            id="twoFactorCode"
                            name="code"
                            inputmode="numeric"
                            autocomplete="one-time-code"
                            pattern="[0-9]{6}"
                            maxlength="6"
                            placeholder="123456"
                            required
                        >
                    </div>
                    <input type="hidden" name="_token" value="{{ csrf_token('account_two_factor_enable') }}">
                    <div class="two-factor-actions">
                        <button class="btn btn-primary" type="submit">Activer la double authentification</button>
                    </div>
                </form>

                <form method="post" action="{{ path('app_account_two_factor_cancel') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('account_two_factor_cancel') }}">
                    <button class="btn btn-ghost" type="submit">Annuler la configuration</button>
                </form>
            {% elseif twoFactorEnabled %}
                <form method="post" action="{{ path('app_account_two_factor_disable') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('account_two_factor_disable') }}">
                    <button class="btn btn-ghost" type="submit">Désactiver</button>
                </form>
            {% else %}
                <form method="post" action="{{ path('app_account_two_factor_start') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('account_two_factor_start') }}">
                    <button class="btn btn-primary" type="submit">Configurer avec un QR code</button>
                </form>
            {% endif %}
        </section>
    {% endif %}
</div>
{% endblock %}
